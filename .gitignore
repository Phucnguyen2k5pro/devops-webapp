deploy/docker-compose.local.yml
deploy/Caddyfile.local
.env.local
.env.local.*
devops-webapp-prod.tar.gz
deploy-src.tar.gz

# Archives should not be committed to source repo
*.zip
*.tar
*.tar.gz
*.tgz

