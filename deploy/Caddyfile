{$PRODUCTION_DOMAIN} {
    encode gzip

    reverse_proxy app:3000

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

{$GRAFANA_DOMAIN} {
    encode gzip

    reverse_proxy grafana:3000

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
