# Docker image built and pushed by CI/CD.
# Example:
# WEB_IMAGE=docker.io/nguyenttphuc/devops-webapp:commit-sha-here
WEB_IMAGE=docker.io/nguyenttphuc/devops-webapp:replace-with-commit-sha

# Production domains
PRODUCTION_DOMAIN=nhom1phuc.io.vn
GRAFANA_DOMAIN=grafana.nhom1phuc.io.vn

# Grafana admin account.
# Do not commit the real production password.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
